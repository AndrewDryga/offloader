
# coop working state (commit knowledge, ignore state)
.agent/*
!.agent/rules/
!.agent/skills/

# .gemini may be globally ignored (local Gemini state); keep just the skills symlink
!.gemini/
.gemini/*
!.gemini/skills

# Stray runtime artifacts (Elixir writes this when the VM crashes on boot)
erl_crash.dump

# docs/ is the committed source of truth (P00/D01/D02/O01/P03) — do NOT ignore it.

# Release artifacts (dev/scripts/release.sh)
dist/

# Go CLI build output (built to /tmp or dist/, never committed)
tools/tools
tools/offloader

# Docs-site build tooling deps (the generator + generated site/docs/*.html are committed)
node_modules/
dev/docs-site/node_modules/

# Terraform local state + provider cache (infra/). Terraform Cloud manages the provider
# lock (a lock generated here would miss linux_amd64 hashes and break the TFC run).
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info
crash.log
